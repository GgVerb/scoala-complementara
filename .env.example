# Configurație pentru Școala Complementară
# Copiați acest fișier ca .env și completați valorile

# ===========================================
# CONFIGURAȚIE BAZĂ DE DATE
# ===========================================
# Conexiunea la PostgreSQL
DATABASE_URL=postgresql://username:password@localhost:5432/database_name

# Exemplu pentru server local:
# DATABASE_URL=postgresql://scoala_complementara:your_password@localhost:5432/scoala_complementara_db

# Exemplu pentru server extern:
# DATABASE_URL=postgresql://username:password@your-database-host.com:5432/database_name

# ===========================================
# CONFIGURAȚIE MEDIU
# ===========================================
# Setați pe "production" pentru server-ul live
NODE_ENV=production

# Port-ul pe care rulează aplicația (implicit 3000)
PORT=3000

# ===========================================
# CONFIGURAȚIE EMAIL (OPȚIONAL)
# ===========================================
# Pentru trimiterea emailurilor prin SendGrid
# Creați un cont la https://sendgrid.com și obțineți API key-ul
SENDGRID_API_KEY=your_sendgrid_api_key_here

# Email-ul de la care se trimit notificările
FROM_EMAIL=noreply@your-domain.com

# Email-ul care primește notificările de contact
TO_EMAIL=contact@your-domain.com

# ===========================================
# CONFIGURAȚIE GOOGLE ANALYTICS (OPȚIONAL)
# ===========================================
# Pentru tracking-ul vizitatorilor
# Creați un cont Google Analytics și obțineți Measurement ID
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ===========================================
# CONFIGURAȚIE SECURITATE (OPȚIONAL)
# ===========================================
# Cheie secretă pentru sesiuni (generați o cheie aleatorie)
SESSION_SECRET=your_very_long_random_secret_key_here

# Durata sesiunii în milisecunde (implicit 24 ore)
SESSION_MAX_AGE=86400000

# ===========================================
# CONFIGURAȚIE DEZVOLTARE (DOAR LOCAL)
# ===========================================
# Urmăriți doar dacă dezvoltați aplicația local
# VITE_DEV_SERVER_URL=http://localhost:5173

# ===========================================
# INSTRUCȚIUNI DE CONFIGURARE
# ===========================================
# 1. Copiați acest fișier ca .env
# 2. Completați DATABASE_URL cu datele bazei dvs.
# 3. Setați NODE_ENV=production
# 4. Configurați PORT-ul dorit (implicit 3000)
# 5. Opțional: Adăugați SENDGRID_API_KEY pentru emailuri
# 6. Opțional: Adăugați VITE_GA_MEASUREMENT_ID pentru analytics
# 7. Generați o cheie aleatorie pentru SESSION_SECRET

# Pentru a genera o cheie secretă aleatorie, folosiți:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"